# ============================================================
# KREDITPASS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter le fichier .env avec de vraies valeurs
# ============================================================

# ============================================================
# BACKEND — Render.com
# ============================================================

NODE_ENV=production
PORT=10000

# Base de données PostgreSQL (Neon, Supabase, Railway, ou Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Sécurité des sessions — OBLIGATOIRE (générer avec: openssl rand -hex 32)
SESSION_SECRET=CHANGEME_openssl_rand_hex_32

# Clé de chiffrement pour données sensibles (générer avec: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGEME_openssl_rand_hex_32

# URL du frontend Vercel — OBLIGATOIRE pour CORS (sans slash final)
FRONTEND_URL=https://kreditpass.org

# ============================================================
# EMAIL — SendPulse (service principal transactionnel)
# ============================================================
SENDPULSE_API_ID=votre_api_id_sendpulse
SENDPULSE_API_SECRET=votre_api_secret_sendpulse
SENDPULSE_FROM_EMAIL=noreply@kreditpass.org
SENDPULSE_FROM_NAME=KreditPass

# EMAIL — Resend (service secondaire)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# CLOUDINARY — Stockage fichiers KYC / documents
# ============================================================
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ============================================================
# SUPABASE — Prévisualisation PDF
# ============================================================
SUPABASE_PROJECT_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=votre_anon_key

# ============================================================
# COMPTE ADMIN (créé automatiquement au 1er démarrage)
# ============================================================
ADMIN_EMAIL=admin@kreditpass.org
ADMIN_PASSWORD=MotDePasseAdmin123!

# ============================================================
# PUPPETEER — Génération PDF (configuré automatiquement sur Render)
# ============================================================
PUPPETEER_CACHE_DIR=/opt/render/project/.cache/puppeteer
PUPPETEER_EXECUTABLE_PATH=/opt/render/project/.cache/puppeteer/chrome/linux-*/chrome-linux64/chrome

# ============================================================
# OPTIONNEL
# ============================================================
# Monitoring erreurs production (Sentry)
SENTRY_DSN=
SENTRY_RELEASE=1.0.0

# Reset le mot de passe admin au démarrage (true/false)
RESET_ADMIN_PASSWORD=false

# Debug sessions (dev uniquement)
DEBUG_SESSIONS=false

# ============================================================
# FRONTEND — Vercel.com
# ============================================================

# URL de l'API backend Render — OBLIGATOIRE (sans slash final)
VITE_API_URL=https://api.kreditpass.org

# URL du serveur WebSocket (identique à VITE_API_URL)
VITE_SOCKET_URL=https://api.kreditpass.org

# URL publique du site frontend
VITE_SITE_URL=https://kreditpass.org
